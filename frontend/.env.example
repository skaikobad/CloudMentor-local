# CloudMentor frontend environment examples
# Copy this file to .env, then keep only ONE active VITE_API_BASE_URL line.

# 1) Local laptop mode: React at localhost:5173 calls SAM Local backend at localhost:3000
VITE_API_BASE_URL=http://localhost:3000

# 2) EC2 mode: React build is served by Nginx from EC2 public IP, and /api proxies to SAM Local
# VITE_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP/api

# 3) Full AWS serverless mode: React calls API Gateway directly
# VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com
