# --------------------------------------------------
# CloudMentor .gitignore
# Keep source code and example files, exclude secrets,
# local builds, dependencies, logs, and deployment state.
# --------------------------------------------------

# Dependencies
node_modules/
**/node_modules/

# Frontend environment files
frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env*.example

# Backend local/SAM environment files containing secrets
backend/env.json
backend/env.*.json
!backend/env.*.example.json

# Root environment files
.env
.env.*
!.env.example
!.env*.example

# npm/yarn/pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Frontend build output
frontend/dist/
frontend/build/
dist/
build/

# AWS SAM / CloudFormation local build and deploy state
.aws-sam/
backend/.aws-sam/
samconfig.toml
samconfig.*.toml

# Test/coverage artifacts
coverage/
.nyc_output/

# Local upload/temp artifacts
uploads/
tmp/
temp/
*.tmp

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generated archives
*.zip
